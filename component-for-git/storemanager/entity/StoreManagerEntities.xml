<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!-- The Base Product Table -->
    <entity entity-name="SmProduct" package="storemanager">
        <field name="productId" type="id" is-pk="true"/>
        <field name="productName" type="text-medium"/>
        <field name="price" type="currency-amount"/>
        <field name="currentStock" type="number-integer"/>
        <field name="soldQuantity" type="number-integer"/>
    </entity>

    <!-- The "Wow Factor" Analytics View -->
    <!-- This instantly calculates (Price * SoldQuantity) on the database level -->
    <view-entity entity-name="SmProductRevenueView" package="storemanager">
        <member-entity entity-alias="SP" entity-name="storemanager.SmProduct"/>
        <alias-all entity-alias="SP"/>
        <alias name="totalRevenue" type="currency-amount">
            <complex-alias operator="*">
                <complex-alias-field entity-alias="SP" field="price"/>
                <complex-alias-field entity-alias="SP" field="soldQuantity"/>
            </complex-alias>
        </alias>
    </view-entity>

</entities>
