<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd">

    <!-- CRUD Transitions (Auto-handled by Moqui framework) -->
    <transition name="createProduct">
        <service-call name="create#storemanager.SmProduct"/>
        <default-response url="."/>
    </transition>
    
    <transition name="updateProduct">
        <service-call name="update#storemanager.SmProduct"/>
        <default-response url="."/>
    </transition>
    
    <transition name="deleteProduct">
        <service-call name="delete#storemanager.SmProduct"/>
        <default-response url="."/>
    </transition>

    <!-- Custom Logic Transition (The Wow Factor) -->
    <transition name="simulateSale">
        <service-call name="storemanager.StoreManagerServices.record#QuickSale"/>
        <default-response url="."/>
    </transition>

    <actions>
        <!-- Fetch our custom database view that instantly calculates Total Revenue per product -->
        <entity-find entity-name="storemanager.SmProductRevenueView" list="productList">
            <order-by field-name="productName"/>
        </entity-find>
    </actions>

    <widgets>
        <container style="q-pa-md">
            
            <label text="1) Manager CRUD Action" type="h4" style="text-primary"/>
            <container-dialog id="AddProductDialog" button-text="Add New Product To Store" type="success">
                <form-single name="AddProductForm" transition="createProduct">
                    <!-- ID is auto-generated by the create service if left blank -->
                    <field name="productId"><default-field><ignored/></default-field></field>
                    
                    <field name="productName"><default-field title="Brand / Name"><text-line size="30"/></default-field></field>
                    <field name="price"><default-field title="Price ($)"><text-line size="10"/></default-field></field>
                    <field name="currentStock"><default-field title="Initial Stock in Warehouse"><text-line size="10"/></default-field></field>
                    
                    <!-- New products start with 0 sold -->
                    <field name="soldQuantity"><default-field><hidden default-value="0"/></default-field></field>
                    
                    <field name="submitButton"><default-field title="Save Product ->"><submit/></default-field></field>
                </form-single>
            </container-dialog>

            <label text="2) Live Reporting &amp; Simulation" type="h4" style="q-mt-lg text-primary"/>
            <label text="Use standard update/delete, or click [ Simulate 1 Sale ] to watch Moqui run real-time math on Inventory &amp; Revenue." type="p"/>
            
            <!-- form-list handles Read and Update for CRUD. show-csv-button automatically lets managers export data to CSV! -->
            <form-list name="ProductTable" list="productList" transition="updateProduct" show-csv-button="true">
                <field name="productId"><default-field><hidden/></default-field></field>
                
                <field name="productName"><default-field title="Product"><display/></default-field></field>
                
                <!-- Editable during "Update" CRUD -->
                <field name="price"><default-field title="Price ($)"><text-line size="6"/></default-field></field>
                <field name="currentStock"><default-field title="Current Stock"><text-line size="6"/></default-field></field>
                
                <!-- Display Only Metrics -->
                <field name="soldQuantity"><default-field title="Units Sold"><display/></default-field></field>
                
                <!-- The Auto-Calculated 'Total Revenue' from our View Entity -->
                <field name="totalRevenue">
                    <default-field title="Total Revenue (Calculated)">
                        <!-- Format nicely as currency -->
                        <display currency-unit="USD"/>
                    </default-field>
                </field>
                
                <!-- Action Buttons per row -->
                <field name="updateBtn"><default-field title="Update"><submit/></default-field></field>
                <field name="deleteBtn">
                    <default-field title="Delete">
                        <link url="deleteProduct" text="Delete" confirmation="Are you sure you want to remove this product?" btn-type="danger"/>
                    </default-field>
                </field>
                
                <field name="quickSaleBtn">
                    <default-field title="Logic Test">
                        <!-- Ties back to our simulateSale transition & custom service -->
                        <link url="simulateSale" text="[ Simulate 1 Sale ]" btn-type="success"/>
                    </default-field>
                </field>
            </form-list>
            
        </container>
    </widgets>
</screen>
